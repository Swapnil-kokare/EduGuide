{
  "name": "career-guide-pro",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npm run install:all",
    "dev": "npm run dev:all",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently \"npm --prefix frontend run dev\" \"npm --prefix backend run dev\"",
    "install:frontend": "npm --prefix frontend install",
    "install:backend": "npm --prefix backend install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix backend run test && npm --prefix frontend run test",
    "seed": "npm --prefix backend run seed",
    "import:official-colleges": "npm --prefix backend run import:official-colleges",
    "import:official-cutoffs": "npm --prefix backend run import:official-cutoffs",
    "import:mahacet-jsonl": "npm --prefix backend run import:mahacet-jsonl",
    "migrate:feedback": "npm --prefix backend run migrate:feedback"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "mongoose": "^9.4.1"
  }
}
